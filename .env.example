# 企业微信机器人 Webhook。建议用仅允许该机器人发送的群。
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-me

# 轮询频率。P0/P1/P2 都由程序根据注册表优先级控制；这里是基础 tick。
POLL_INTERVAL_MINUTES=30

# 事件沉淀窗口：发现新模型事件后先等一段时间聚合多个来源，再推送一条完整消息。
EVENT_SETTLE_MINUTES=45

# 首次启动默认只建立基线，不推送历史旧消息。
BOOTSTRAP_NOTIFY=false

# true 时只打印通知内容，不发企业微信。
DRY_RUN=false

# 可选：提高 GitHub 市场热度/开发者讨论量统计额度。
GITHUB_TOKEN=

# 可选：用于生成更好的中文摘要和评分。兼容 OpenAI 风格 /v1/chat/completions。
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
